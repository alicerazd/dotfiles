# -*-mode:conf-toml-*- vim:ft=toml

# ~/.local/share/chezmoi/.chezmoi.toml.tmpl
# =============================================================================
# Used to customize configuration when doing a `chezmoi init`.
#
# This template file will trigger prompts to fill-in machine-specific
# templateable values. The resulting file is then created at
# `~/.config/chezmoi/chezmoi.toml`
# See https://www.chezmoi.io/docs/how-to/
#
# {{- /* This file supports Go's text/template language. */}}

{{- $isCodespaces := env "CODESPACES" | not | not }}
{{- $isGitHubActions := env "GITHUB_ACTIONS" | not | not }}
{{- $isCI := or $isGitHubActions $isCodespaces }}

{{- $email := "" }}
{{- $name := "" }}

{{- if $isCodespaces }}
{{-   $email = "codespace@github.com" }}
{{-   $name = env "GITHUB_USER" }}
{{- else if not $isCI }}
{{-   $email = promptString "Git email address for the author/committer" }}
{{-   $name = promptString "Git username for the author/committer" }}
{{- end }}

[data]
    email = "{{ $email }}"
    name = "{{ $name }}"
    isCodespaces = {{ $isCodespaces }}
    isCI = {{ $isCI }}
