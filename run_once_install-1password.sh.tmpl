#!/bin/sh
# -*-mode:sh-*- vim:ft=shell-script

# run_once_install-1password.sh.tmpl
# =============================================================================
# Installs and configures 1Password CLI for secrets management and SSH agent.
# This script runs once during chezmoi initialization.

{{ if .use1Password -}}

set -e

echo "Installing 1Password CLI..."

# Detect platform
PLATFORM="unknown"
if [ "$(uname)" = "Darwin" ]; then
    PLATFORM="macos"
elif [ "$(uname)" = "Linux" ]; then
    PLATFORM="linux"
elif [ -n "$WSL_DISTRO_NAME" ] || [ -n "$WSLENV" ]; then
    PLATFORM="wsl"
fi

echo "Platform: $PLATFORM"

install_op_cli() {
    if command -v op >/dev/null 2>&1; then
        echo "✓ 1Password CLI already installed: $(op --version)"
        return 0
    fi

    case "$PLATFORM" in
        macos)
            if command -v brew >/dev/null 2>&1; then
                echo "Installing 1Password CLI via Homebrew..."
                brew install --cask 1password-cli || {
                    echo "Failed to install via Homebrew, trying direct download..."
                    return 1
                }
            else
                echo "Homebrew not found. Installing 1Password CLI directly..."
                curl -sS https://downloads.1password.com/mac/1password-cli-latest.pkg -o /tmp/op.pkg
                sudo installer -pkg /tmp/op.pkg -target /
                rm /tmp/op.pkg
            fi
            ;;
        linux|wsl)
            # Add 1Password's GPG key and repository
            if command -v apt-get >/dev/null 2>&1; then
                echo "Installing 1Password CLI via apt..."
                curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
                    sudo gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg
                echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" | \
                    sudo tee /etc/apt/sources.list.d/1password.list
                sudo mkdir -p /etc/debsig/policies/AC2D62742012EA22/
                curl -sS https://downloads.1password.com/linux/debian/debsig/1password.pol | \
                    sudo tee /etc/debsig/policies/AC2D62742012EA22/1password.pol
                sudo mkdir -p /usr/share/debsig/keyrings/AC2D62742012EA22
                curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
                    sudo gpg --dearmor --output /usr/share/debsig/keyrings/AC2D62742012EA22/debsig.gpg
                sudo apt-get update && sudo apt-get install -y 1password-cli
            elif command -v yum >/dev/null 2>&1; then
                echo "Installing 1Password CLI via yum..."
                sudo rpm --import https://downloads.1password.com/linux/keys/1password.asc
                sudo sh -c 'echo -e "[1password]\nname=1Password Stable Channel\nbaseurl=https://downloads.1password.com/linux/rpm/stable/\$basearch\nenabled=1\ngpgcheck=1\nrepo_gpgcheck=1\ngpgkey=https://downloads.1password.com/linux/keys/1password.asc" > /etc/yum.repos.d/1password.repo'
                sudo yum install -y 1password-cli
            else
                echo "⚠️  Unsupported package manager. Please install 1Password CLI manually:"
                echo "    https://developer.1password.com/docs/cli/get-started"
                return 1
            fi
            ;;
        *)
            echo "⚠️  Unknown platform. Please install 1Password CLI manually:"
            echo "    https://developer.1password.com/docs/cli/get-started"
            return 1
            ;;
    esac
    
    if command -v op >/dev/null 2>&1; then
        echo "✓ 1Password CLI installed successfully: $(op --version)"
        return 0
    else
        echo "✗ Failed to install 1Password CLI"
        return 1
    fi
}

# Install 1Password CLI
install_op_cli || {
    echo "Continuing without 1Password CLI..."
}

# Configure 1Password SSH agent
if command -v op >/dev/null 2>&1; then
    echo ""
    echo "✓ 1Password CLI installed"
    echo ""
    echo "To complete 1Password setup:"
    echo "  1. Sign in to 1Password: op signin"
    echo "  2. Enable 1Password SSH agent in 1Password app settings"
    echo "  3. Restart your shell to use 1Password features"
    echo ""
    echo "Your shell configuration will automatically detect and use:"
    echo "  - 1Password SSH agent"
    echo "  - 1Password secret references in .env files"
    echo ""
fi

{{ else -}}
echo "1Password integration not enabled - skipping installation"
echo "To enable later, run: chezmoi init and answer 'yes' to 1Password prompt"
{{ end -}}
