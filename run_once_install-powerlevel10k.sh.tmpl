#!/bin/sh
# -*-mode:sh-*- vim:ft=shell-script

# run_once_install-powerlevel10k.sh.tmpl
# =============================================================================
# Installs Powerlevel10k theme for Oh My Zsh.
# This script runs once during chezmoi initialization.

set -e

ZSH_CUSTOM="${ZSH_CUSTOM:-${HOME}/.oh-my-zsh/custom}"
P10K_DIR="${ZSH_CUSTOM}/themes/powerlevel10k"

# Check if Powerlevel10k is already installed
if [ -d "$P10K_DIR" ]; then
    echo "Powerlevel10k is already installed, skipping..."
    exit 0
fi

# Ensure Oh My Zsh is installed first
if [ ! -d "${HOME}/.oh-my-zsh" ]; then
    echo "Oh My Zsh is not installed, please install it first"
    exit 1
fi

echo "Installing Powerlevel10k theme..."

# Clone Powerlevel10k repository
git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$P10K_DIR" || {
    echo "Failed to install Powerlevel10k"
    exit 1
}

echo "✓ Powerlevel10k installed successfully"
